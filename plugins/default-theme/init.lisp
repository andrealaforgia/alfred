;;; name: default-theme
;;; version: 0.2.0
;;; description: Default color theme for Alfred (Catppuccin Mocha-inspired)

;; UI colors
(set-theme-color "text-fg" "default")
(set-theme-color "text-bg" "default")
(set-theme-color "gutter-fg" "#6c7086")
(set-theme-color "gutter-bg" "default")
(set-theme-color "status-bar-fg" "#cdd6f4")
(set-theme-color "status-bar-bg" "#313244")
(set-theme-color "message-fg" "default")
(set-theme-color "message-bg" "default")

;; Syntax highlighting colors (Catppuccin Mocha palette)
(set-theme-color "syntax-keyword" "#c678dd")
(set-theme-color "syntax-function" "#89b4fa")
(set-theme-color "syntax-string" "#a6e3a1")
(set-theme-color "syntax-comment" "#6c7086")
(set-theme-color "syntax-type" "#f9e2af")
(set-theme-color "syntax-variable" "#cdd6f4")
(set-theme-color "syntax-operator" "#89dceb")
(set-theme-color "syntax-number" "#fab387")
(set-theme-color "syntax-punctuation" "#9399b2")
(set-theme-color "syntax-property" "#b4befe")
(set-theme-color "syntax-attribute" "#f9e2af")
(set-theme-color "syntax-constant" "#fab387")
(set-theme-color "syntax-constructor" "#fab387")
